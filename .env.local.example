# ============================================================
# Supabase — from your project Settings → API
# ============================================================
# Used by the browser client and the server client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used for privileged operations (e.g. cron that
# deletes photos older than 24h). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Where magic-link emails redirect back to after the user clicks.
# In local dev this is http://localhost:3000. In production use
# your real domain, e.g. https://nutrition-tracker.example.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Google Gemini — required for the AI nutrition estimator (M4+).
# Grab a key at https://aistudio.google.com/app/apikey
# The app uses Gemini 2.5 Flash by default. Google offers a
# generous free tier (no credit card required) that covers
# typical personal use; once you exceed it you're on pay-as-you-go.
# ============================================================
GEMINI_API_KEY=...
